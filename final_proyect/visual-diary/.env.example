# Variables de entorno para VisualDiary
# Copia este archivo como .env y completa los valores

# ─── Firebase ──────────────────────────────────────────────────────────────────
# Obtén estos valores en: https://console.firebase.google.com/
# Proyecto → Configuración del proyecto → Tus apps → Config

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── OpenCage Geocoding API ────────────────────────────────────────────────────
# Obtén tu API Key gratuita en: https://opencagedata.com/
# Plan gratuito: 2500 peticiones/día

VITE_OPENCAGE_API_KEY=tu_api_key_de_opencage
